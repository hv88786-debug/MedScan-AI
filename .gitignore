# ==========================================================
# MedScan AI — .gitignore
# ==========================================================

# ---------- Dependencies ----------
node_modules/
backend/node_modules/
frontend/node_modules/
.pnp
.pnp.js

# ---------- Environment variables ----------
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ---------- Runtime data ----------
pids/
*.pid
*.seed
*.pid.lock

# ---------- Uploaded / generated files ----------
# Reports are only ever stored temporarily by the backend — never commit
# anything a user has actually uploaded.
backend/uploads/*
!backend/uploads/.gitkeep

# ---------- Coverage / testing ----------
coverage/
.nyc_output/
*.lcov

# ---------- Build output ----------
dist/
build/
out/

# ---------- OS files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ---------- Editor / IDE ----------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ---------- Package manager artifacts ----------
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ---------- Misc ----------
*.tgz
.cache/
.temp/
.tmp/
